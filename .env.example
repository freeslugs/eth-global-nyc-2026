# ─────────────────────────────────────────────────────────────────────────────
# Safe Skills adapter selection (see ADR-001-aegis.md). EVERY flag defaults to a
# MOCK implementation, so the repo runs with zero chain / Ledger / Chainlink
# config. Flip ONE flag to bring up ONE real adapter in isolation; the real
# adapters currently throw NotImplementedError until each lane's owner fills it.
# ─────────────────────────────────────────────────────────────────────────────

# SkillResolver — read pin/verdict from ENS.        mock | ens
AEGIS_RESOLVER=mock

# SkillFetcher — pull SKILL.md bytes.               mock | file | ipfs
AEGIS_FETCHER=mock

# InstallSigner — authorize installs.               local | ledger
AEGIS_SIGNER=local

# ReviewClient — Chainlink Confidential AI review.  mock | chainlink
AEGIS_REVIEW=mock

# VerdictWriter — write safeskills.verdict to ENS.  mock | ens
AEGIS_VERDICT=mock

# SubmissionWatcher — the on-chain CRE trigger.     mock | chain
AEGIS_WATCHER=mock

# ─────────────────────────────────────────────────────────────────────────────
# Real-adapter configuration (only needed once a lane's stub is implemented).
# ─────────────────────────────────────────────────────────────────────────────

# Private key for the LocalSigner (dev-only; never commit a real key).
# AEGIS_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# JSON-RPC endpoint for @aegis/chain viem clients (Sepolia).
# AEGIS_RPC_URL=https://sepolia.example.org

# Chainlink Confidential AI endpoints / keys (kept out of the repo; the CRE
# confidential-fetch credential lives as a Chainlink threshold-encrypted secret).
# CONFIDENTIAL_AI_URL=
# CONFIDENTIAL_AI_KEY=

# IPFS gateway for IpfsFetcher.
# IPFS_GATEWAY_URL=https://ipfs.io
