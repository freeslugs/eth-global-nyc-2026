# ─────────────────────────────────────────────────────────────────────────────
# Safe Skills adapter selection (see ADR-001-aegis.md). EVERY flag defaults to a
# MOCK implementation, so the repo runs with zero chain / Ledger / Chainlink
# config. Flip ONE flag to bring up ONE real adapter in isolation; the real
# adapters currently throw NotImplementedError until each lane's owner fills it.
# ─────────────────────────────────────────────────────────────────────────────

# SkillResolver — read pin/verdict from ENS.        mock | ens
# AEGIS_RESOLVER=mock
AEGIS_RESOLVER=ens

# SkillFetcher — pull SKILL.md bytes.               mock | file | ipfs
AEGIS_FETCHER=mock

# Signer backend — authorizes installs AND signs on-chain txs (policies, ENS,
# Chainlink). Drives both InstallSigner and @aegis/chain's makeAccount().
# `ledger` signs on a physical device over USB-HID (node/CLI only).
#                                                   local | ledger
AEGIS_SIGNER=local

# ReviewClient — Chainlink Confidential AI review.  mock | chainlink
AEGIS_REVIEW=mock

# VerdictWriter — write safeskills.verdict to ENS.  mock | ens
AEGIS_VERDICT=mock

# SubmissionWatcher — the on-chain CRE trigger.     mock | chain
AEGIS_WATCHER=mock

# ─────────────────────────────────────────────────────────────────────────────
# Real-adapter configuration (only needed once a lane's stub is implemented).
# ─────────────────────────────────────────────────────────────────────────────

# Local-mode signing key (AEGIS_SIGNER=local), used by LocalSigner AND the
# @aegis/chain wallet client. DEV BURNER ONLY — never commit a real key, and do
# NOT use the well-known Anvil key on a public testnet (anyone can sweep its
# faucet funds / grief its nonce). Generate a fresh one:
#   pnpm --filter @aegis/chain exec node --input-type=module \
#     -e "import {generatePrivateKey,privateKeyToAccount} from 'viem/accounts';\
#         const k=generatePrivateKey();console.log(k,privateKeyToAccount(k).address)"
# Then fund the address from a Sepolia faucet (e.g. sepoliafaucet.com).
# AEGIS_PRIVATE_KEY=0x...

# JSON-RPC endpoint for @aegis/chain viem clients (Sepolia). The public node
# works for reads + the deploy; for heavy/reliable broadcasts use a real provider
# (Alchemy/Infura/your node).
AEGIS_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Ledger only (AEGIS_SIGNER=ledger): BIP-44 path of the account to sign with.
# Defaults to the first account if unset.
# AEGIS_LEDGER_PATH=44'/60'/0'/0/0

# ── ENS v2 (Sepolia) ─────────────────────────────────────────────────────────
# Addresses live in @aegis/chain/ens.ts (the sepolia-official-2026-05-25 set);
# ENS v2 Sepolia is reset periodically, so re-pull if reads/writes start failing.
#
# Attestation providers — comma-separated ENS names whose `safeskills.attestation
# .<provider>` slots the resolver reads and the setup/deploy scripts delegate.
# AEGIS_PROVIDERS=chainlink.eth,my-local-verifier.eth
#
# Address each provider's attestation key is delegated to (who may write it).
# Defaults to the AEGIS_PRIVATE_KEY account so one wallet can play every provider.
# AEGIS_PROVIDER_ADDR=0x...
#
# ── Live Aegis deployment on Sepolia (safeskills.eth → acme → weather/exfil) ──
# Public on-chain addresses — safe to commit. Override only to deploy your own.
#
# Your resolver — the skills' records (pins + attestations) live here:
AEGIS_ENS_RESOLVER=0xaC3C69ac919226AA68749387F6FeD2c7c6147654
#
# safeskills.eth's subregistry (orgs register under it). Same value the web uses
# as NEXT_PUBLIC_ORG_REGISTRY; also lets ens-deploy.ts resume without redeploying.
AEGIS_SAFESKILLS_REGISTRY=0xeb5A6844C1C09F1DdDfb83cb4257943EBE80F3a4
NEXT_PUBLIC_ORG_REGISTRY=0xeb5A6844C1C09F1DdDfb83cb4257943EBE80F3a4
#
# The acme org's subregistry (skills register under it):
AEGIS_ACME_REGISTRY=0x9b469d1DA391B243797279f6dA748468226228EB
#
# Admin key for the web /api/authorize route — SERVER-SIDE SECRET (never
# NEXT_PUBLIC, never commit the value). The deployer wallet that owns
# safeskills.eth's subregistry; the route uses it to grant a new wallet
# ROLE_REGISTRAR so it can self-serve create a company. Set this in Vercel.
# AEGIS_ADMIN_KEY=0x...

# Chainlink Confidential AI endpoints / keys (kept out of the repo; the CRE
# confidential-fetch credential lives as a Chainlink threshold-encrypted secret).
# CONFIDENTIAL_AI_URL=
# CONFIDENTIAL_AI_KEY=

# IPFS gateway for IpfsFetcher.
# IPFS_GATEWAY_URL=https://ipfs.io
