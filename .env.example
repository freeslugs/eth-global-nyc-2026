# ─────────────────────────────────────────────────────────────────────────────
# Aegis adapter selection. Every flag defaults to a MOCK implementation so the
# repo runs with zero chain configuration. Switch any flag to its "real" value
# to reach a (currently stubbed) adapter that throws NotImplementedError —
# proving the seam exists without being implemented yet.
# ─────────────────────────────────────────────────────────────────────────────

# Resolver: where artifact pins come from.  mock | ens
AEGIS_RESOLVER=mock

# Signer: who signs provenance / revocations.  local | ledger
AEGIS_SIGNER=local

# Attestation store: where pins + attestations live.  memory | onchain
AEGIS_STORE=memory

# Confidential attester (Chainlink lane).  off | chainlink
AEGIS_CONFIDENTIAL=off

# Fetcher: where artifacts are pulled from.  file | npm
AEGIS_FETCHER=file

# Optional override for the seeded registry JSON used by the mock adapters.
# AEGIS_SEED_PATH=./packages/adapters/fixtures/registry.seed.json

# ─────────────────────────────────────────────────────────────────────────────
# Real-adapter configuration (only needed once the stubs are implemented).
# ─────────────────────────────────────────────────────────────────────────────

# Private key for the LocalSigner (viem). Dev-only; never commit a real key.
# AEGIS_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# JSON-RPC endpoint for @aegis/chain viem clients.
# AEGIS_RPC_URL=https://sepolia.example.org
