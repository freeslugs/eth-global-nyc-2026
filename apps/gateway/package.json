{
  "name": "@aegis/gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "gate:check": "node dist/index.js --check echo-server.aegis.eth",
    "demo": "node scripts/demo.js",
    "poison": "node scripts/swap-poison.js",
    "restore": "node scripts/swap-poison.js --restore",
    "pin": "node scripts/pin.js"
  },
  "dependencies": {
    "@aegis/adapters": "workspace:*",
    "@aegis/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "picocolors": "^1.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@aegis/eslint-config": "workspace:*",
    "@aegis/tsconfig": "workspace:*",
    "@types/node": "^20.17.0",
    "eslint": "^9.18.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
